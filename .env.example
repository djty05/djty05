# Pushbullet API key for push notifications (optional)
# Get yours at https://www.pushbullet.com/#settings/account
PUSHBULLET_API_KEY=

# Email notifications (optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# Scan interval in minutes (default: 5)
SCAN_INTERVAL_MINUTES=5

# Discord webhook URL for notifications (optional)
DISCORD_WEBHOOK_URL=
# Discord user ID to ping on new listings (optional)
DISCORD_USER_ID=
